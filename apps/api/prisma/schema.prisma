generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Local development uses SQLite (file:./dev.db) for zero-config setup.
  //
  // Before deploying to production (Render + Neon Postgres), run:
  //     cd apps\api
  //     npm run prepare:prod   # flips this provider to "postgresql"
  //     npx prisma migrate dev --name init   # against your Neon URL
  //
  // After that, commit prisma/migrations and push — Render will replay them.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  email         String   @unique
  phone         String?
  name          String?
  firstName     String?
  lastName      String?
  passwordHash  String?
  referralCode  String   @unique
  referredById  String?
  role          String   @default("user")
  status        String   @default("active") // active|blocked
  kycVerified   Boolean  @default(false)
  lastLoginAt   DateTime?
  lastIp        String?
  ReferralEdges ReferralEdge[] @relation("ref_edges_parent")
  ReferralChild ReferralEdge?  @relation("ref_edges_child")
  Investments   Investment[]
  Wallets       Wallet[]
  DailyClaims   DailyClaim[]
  Withdrawals   Withdrawal[]
  Transactions  Transaction[]
  Deposits      Deposit[]
  Notifications Notification[]
}

model Plan {
  id           String   @id @default(cuid())
  name         String
  price        Int
  dailyIncome  Int
  durationDays Int
  active       Boolean  @default(true)
  Investments  Investment[]
}

model Investment {
  id          String   @id @default(cuid())
  userId      String
  planId      String
  startedAt   DateTime @default(now())
  endsAt      DateTime
  remainingDays Int
  status      String   @default("active")
  User        User     @relation(fields: [userId], references: [id])
  Plan        Plan     @relation(fields: [planId], references: [id])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  type      String   // deposit|earnings|bonus|referral|withdrawal
  balance   Decimal  @default(0)
  User      User     @relation(fields: [userId], references: [id])
  @@unique([userId, type])
}

model Transaction {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  userId       String
  walletType   String
  amount       Decimal
  direction    String   // credit|debit
  reason       String
  refId        String?
  idempotencyKey String? @unique
  User         User     @relation(fields: [userId], references: [id])
}

model DailyClaim {
  id        String   @id @default(cuid())
  userId    String
  claimedAt DateTime @default(now())
  dayKey    String
  amount    Decimal  @default(0)
  User      User     @relation(fields: [userId], references: [id])
  @@unique([userId, dayKey])
}

model Withdrawal {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  amount      Decimal
  feePercent  Int
  netAmount   Decimal
  method      String
  accountJson String
  status      String   @default("pending")
  payoutRef   String?
  User        User     @relation(fields: [userId], references: [id])
}

model ReferralEdge {
  id          String   @id @default(cuid())
  parentId    String
  childId     String   @unique
  level       Int
  createdAt   DateTime @default(now())
  Parent      User     @relation("ref_edges_parent", fields: [parentId], references: [id])
  Child       User     @relation("ref_edges_child", fields: [childId], references: [id])
}

model VipLevel {
  id                String   @id @default(cuid())
  name              String
  requiredBusiness  Int
}

model Deposit {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  amount      Decimal
  method      String   // razorpay|upi|manual_utr
  utr         String?
  gatewayRef  String?
  status      String   @default("pending") // pending|approved|rejected
  reviewedBy  String?
  reviewedAt  DateTime?
  note        String?
  User        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  User      User     @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  action    String
  meta      String?
  ip        String?
}

model DailyReward {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  type      String   // spin|scratch
  dayKey    String
  amount    Decimal  @default(0)
  meta      String?
  @@unique([userId, type, dayKey])
}

/// Admin-configurable payment channels (UPI IDs, bank accounts, etc.)
/// shown on the user wallet page. The default channel becomes the primary QR.
model PaymentChannel {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  /// kind: "upi" | "bank" | "crypto" | "other"
  kind        String   @default("upi")
  /// label shown to the user, e.g. "Primary UPI (PhonePe)"
  label       String
  /// the actual value — UPI VPA, account number, etc.
  value       String
  /// payee name shown in UPI deep link
  payeeName   String   @default("RupeeRise")
  /// free-form extra notes shown next to the channel
  note        String?
  /// extra fields json — bank ifsc, holder name, crypto network, etc.
  metaJson    String?
  active      Boolean  @default(true)
  isDefault   Boolean  @default(false)
  /// optional UI ordering — lower comes first
  sortOrder   Int      @default(0)
}

/// Generic key-value store for admin-configurable JSON settings.
/// Keys we use:
///   "reward_config"  → { spin: {prizes: number[], weights?: number[]}, scratch: {table: {amount,weight}[]}, spin_enabled, scratch_enabled, daily_max_per_user }
///   "support_config" → { contacts: [{kind,label,handle,url,note}], channels: [{label,url,icon,note}] }
model AppSetting {
  key       String   @id
  value     String   // JSON string
  updatedAt DateTime @updatedAt
}

/// Admin-issued promo / gift codes that any user can redeem to top up the
/// bonus wallet. Single-use by default (maxClaims=1). For mass-distribution
/// vouchers, increase maxClaims and the same code is shared by many users.
model GiftCode {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  /// Public alphanumeric code (uppercased, unique). Users enter this.
  code        String      @unique
  /// INR credited to bonus wallet on each successful claim.
  amount      Int
  /// Hard cap on total claims. 1 = single-use voucher.
  maxClaims   Int         @default(1)
  /// Counter incremented atomically on each claim.
  claimsCount Int         @default(0)
  /// Optional auto-expiry (UTC). Null = never expires.
  expiresAt   DateTime?
  /// active|disabled — admins can disable without deleting (audit trail).
  status      String      @default("active")
  /// Internal notes (e.g. "Diwali 2025 campaign").
  notes       String?
  /// Admin user id who created this code.
  createdBy   String?
  /// One claim record per (code, user). Enforces "no double claim" via DB.
  Claims      GiftClaim[]
}

/// One row per (giftCode, user) successful redemption. Acts as the
/// idempotency check for repeat redemption attempts on multi-use codes.
model GiftClaim {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  giftCodeId  String
  userId      String
  amount      Int
  GiftCode    GiftCode @relation(fields: [giftCodeId], references: [id], onDelete: Cascade)
  @@unique([giftCodeId, userId])
}

/// Admin-managed promotional posters that auto-swipe at the top of the
/// landing page. Each row is one slide; admins can add/edit/reorder/disable
/// at any time without code changes.
model Poster {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Headline shown on the slide.
  title     String
  /// Subtitle / supporting line.
  subtitle  String?
  /// Public image URL (any CDN/Imgur/Cloudinary). When empty we render a
  /// generated gradient backdrop.
  imageUrl  String?
  /// Tailwind gradient classes used when imageUrl is empty, e.g.
  /// "from-yellow-500/30 via-amber-500/10 to-transparent".
  gradient  String   @default("from-yellow-500/30 via-amber-500/10 to-transparent")
  /// Optional CTA target — either an internal path (#plans, /login) or full URL.
  ctaHref   String?
  /// Optional CTA button label, e.g. "Claim now" or "View plans".
  ctaLabel  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
}

/// One round of the Lucky Hit / Color Prediction mini-game.
/// A new round is created lazily every `roundDurationSec` seconds (default 180 = 3 min)
/// aligned to wall-clock minutes in IST. Bets are accepted while `status='open'`,
/// frozen during the last `lockSeconds` seconds (`status='locked'`), then the
/// server picks a weighted-random `result` and transitions to `status='settled'`,
/// crediting winners' earnings wallets via `postLedger()`.
model LuckyHitRound {
  id             String   @id @default(cuid())
  /// Human-friendly slot id, e.g. "20260529-2118" (YYYYMMDD-HHMM in IST). Unique
  /// per slot so concurrent reads can use upsert-by-period for idempotent creation.
  period         String   @unique
  startedAt      DateTime
  endsAt         DateTime
  /// "open" | "locked" | "settled"
  status         String   @default("open")
  /// Final result once settled. One of: "red" | "black" | "lucky_hit". Null while open/locked.
  result         String?
  settledAt      DateTime?
  /// Live aggregates updated on every successful bet (also used by the score panel UI).
  redTotal       Decimal  @default(0)
  blackTotal     Decimal  @default(0)
  luckyHitTotal  Decimal  @default(0)
  betCount       Int      @default(0)
  Bets           LuckyHitBet[]
  @@index([startedAt])
  @@index([status])
}

/// One user's bet on a single Lucky Hit round.
model LuckyHitBet {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  userId       String
  roundId      String
  /// "red" | "black" | "lucky_hit"
  side         String
  amount       Decimal
  /// "deposit" or "bonus" — which wallet was debited (deposit is preferred,
  /// bonus is the fallback when deposit is short).
  walletSource String   @default("deposit")
  /// "pending" while the round is open/locked, then "won" or "lost" once settled.
  status       String   @default("pending")
  /// 0 for losing bets; amount * payoutMultiplier for winning bets.
  payout       Decimal  @default(0)
  settledAt    DateTime?
  Round        LuckyHitRound @relation(fields: [roundId], references: [id])
  @@index([userId, createdAt])
  @@index([roundId])
}

/// Public-facing pseudo-live transaction feed shown on landing/deposit/
/// withdraw pages. Admins can disable individual rows without deleting.
/// We seed this with realistic Indian first-name + city combos so the page
/// feels alive even on a brand-new install.
model FeedEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  /// "deposit" | "withdraw"
  kind      String
  /// Display name shown in the strip, e.g. "Aarav S."
  username  String
  /// City label, e.g. "Mumbai".
  city      String?
  amount    Int
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
}
