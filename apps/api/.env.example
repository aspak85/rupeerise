# =============================================================================
# RupeeRise API — Environment Variables
# =============================================================================
# Copy to `.env` and fill in. Never commit the real `.env`.
# In Render: paste these as Environment Variables in the service settings.
# =============================================================================

# --- Database (Neon Postgres) -------------------------------------------------
# Get this from https://console.neon.tech/ → your project → Connection string.
# IMPORTANT: append ?sslmode=require for Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/rupeerise?sslmode=require"

# --- App secret (REQUIRED in prod) -------------------------------------------
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace_me_with_a_long_random_string_at_least_48_bytes"

# --- Server -------------------------------------------------------------------
NODE_ENV="production"
PORT=4000

# --- CORS / web origin --------------------------------------------------------
# Comma-separated list of allowed frontend origins. Include both apex + www
# and the Vercel preview URL until your custom domain is live.
WEB_ORIGIN="https://yourdomain.com,https://www.yourdomain.com,https://rupeerise.vercel.app"

# --- Admin gating -------------------------------------------------------------
# ADMIN_EMAILS — comma-separated emails allowed to sign in at /admin/login.
# Everyone else is rejected at the door. Keep this list small (ideally just you).
ADMIN_EMAILS="you@yourdomain.com"

# ADMIN_PASSWORD — the password for ALL admin emails above.
# Bcrypt-hashed at boot and saved to User.passwordHash. To rotate the password,
# just change this value and restart the API.
ADMIN_PASSWORD="StrongAdminPassword@2026"

# --- Email / SMTP (Gmail recommended) -----------------------------------------
# Gmail with App Password (free):
#   1) Enable 2-Step Verification at https://myaccount.google.com/security
#   2) Create an App Password at https://myaccount.google.com/apppasswords
#   3) Use that 16-char password as SMTP_PASS below.
# If left blank, OTPs are printed to the API server logs only (dev-style fallback).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="mob308379@gmail.com"
SMTP_PASS="zvjhgahdizjzigbn"
MAIL_FROM="RupeeRise <mob308379@gmail.com>"

# --- Razorpay (instant card/UPI deposits) ------------------------------------
# Get TEST keys: https://dashboard.razorpay.com/app/keys
# Switch to LIVE keys before going live with real users.
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="your_razorpay_secret_here"

# --- Manual UPI fallback ------------------------------------------------------
# Used to seed the first PaymentChannel on a fresh DB. Admins can change/add
# channels later from /admin/payment-channels.
UPI_ID="yourbusiness@upi"

# --- (Optional) Redis ---------------------------------------------------------
# Not required. Used for rate-limiting if you wire it up later.
# REDIS_URL="redis://default:password@host:6379"
