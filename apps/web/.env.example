# =============================================================================
# RupeeRise Web — Environment Variables
# =============================================================================
# Copy to `.env.local` for development, or paste these into Vercel Project
# Settings -> Environment Variables for production.
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# =============================================================================

# --- API base URL -------------------------------------------------------------
#
# Local dev:           http://localhost:4000  (point directly at the API)
#
# Production (single-domain via Vercel rewrite):
#                      /api    (relative path — the Vercel rewrite in
#                              vercel.json proxies /api/* to your Render API)
#
# Production (separate API subdomain, optional):
#                      https://api.yourdomain.in
#
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Razorpay (public key only — safe to expose) ------------------------------
# This is the SAME key id used by the API, just exposed to the browser so the
# Razorpay checkout widget can render. The secret stays server-side.
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXX"

# --- (Optional) Brand --------------------------------------------------------
NEXT_PUBLIC_BRAND_NAME="RupeeRise"
NEXT_PUBLIC_SITE_URL="https://yourdomain.in"
