# ─────────────────────────────────────────────────────────────
# RupeeRise — top-level .gitignore
# Anything below this line stays on YOUR laptop and is never
# pushed to GitHub / Render / Vercel.
# ─────────────────────────────────────────────────────────────

# === SECRETS — never commit these ===
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local
*.pem
*.key

# === Node / package managers ===
node_modules/
.pnpm-store/
.yarn/cache
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === Build outputs ===
**/dist/
**/build/
**/.next/
**/out/
**/.turbo/
**/.vercel/

# === Local databases (dev SQLite) ===
**/*.db
**/*.db-journal
**/*.sqlite
**/*.sqlite-journal
apps/api/prisma/dev.db
apps/api/prisma/dev.db-journal

# === Editor / IDE ===
.vscode/
.idea/
.windsurf/
*.swp
*.swo
.DS_Store
Thumbs.db

# === TypeScript / tooling caches ===
*.tsbuildinfo
.eslintcache

# === Logs ===
logs/
*.log

# === OS junk ===
desktop.ini
$RECYCLE.BIN/

# === Test coverage ===
coverage/
.nyc_output/
